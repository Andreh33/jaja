# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# IDE
.vscode/
.idea/
.claude/settings.local.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit)
.env
.env*.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# drizzle generated meta
drizzle/migrations/

# client uploads (per-user, large, regenerated)
public/uploads/clientes/*
!public/uploads/clientes/.gitkeep

# fuente de datos del equipo (ya copiado a public/equipo/)
personas/

.vercel
.env*.local

# brainstorming companion artifacts
.superpowers/

# local screenshot checks
*-check.jpeg

# playwright mcp artifacts
.playwright-mcp/

# === Plataforma de formación (curso comerciales) ===
# Vídeos fuente y transcodificados: NUNCA a git (pesados, van a Blob)
contenido-curso/*.wmv
contenido-curso/*.mp4
# Intermedios pesados regenerables
contenido-curso/audio/
contenido-curso/frames/
# PDFs: se regeneran y acaban en Blob
contenido-curso/pdfs/
# Backups de Turso (dump local antes de db:push)
backups/
# SÍ se versionan: contenido-curso/transcripciones/ y contenido-curso/preguntas/
